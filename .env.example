# ========================================
# ZeroMind - Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# All API keys below are FREE — no credit card needed!

# ===== LLM APIs (FREE) =====
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://console.groq.com (optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@db:5432/zeromind
REDIS_URL=redis://redis:6379/0

# ===== Authentication =====
JWT_SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth2 (optional)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== Application =====
APP_NAME=ZeroMind
APP_ENV=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Agent Configuration =====
PRIMARY_LLM=gemini
FALLBACK_LLM=groq
MAX_AGENT_STEPS=10
LLM_CACHE_TTL_SECONDS=21600
RATE_LIMIT_RPM=15
